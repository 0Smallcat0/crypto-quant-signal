[importlinter]
root_package = src
include_external_packages = True

[importlinter:contract:domain_independence]
name = Domain must not import business, runtime, backtest, API, or scripts packages
type = forbidden
source_modules =
    src.domain
forbidden_modules =
    src.config
    src.data
    src.features
    src.strategies
    src.portfolio
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:feature_independence]
name = Features must stay neutral and avoid stateful trading layers
type = forbidden
source_modules =
    src.features
forbidden_modules =
    src.config
    src.data
    src.strategies
    src.portfolio
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts
