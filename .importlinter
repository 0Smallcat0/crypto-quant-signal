[importlinter]
root_package = src
include_external_packages = True

[importlinter:contract:domain_independence]
name = Domain must not import business, runtime, backtest, API, or scripts packages
type = forbidden
source_modules =
    src.domain
forbidden_modules =
    src.config
    src.data
    src.features
    src.strategies
    src.portfolio
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:data_boundary]
name = Data must stay public-data-only and avoid trading layers
type = forbidden
source_modules =
    src.data
forbidden_modules =
    src.config
    src.features
    src.strategies
    src.portfolio
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:config_boundary]
name = Config must not import runtime or business implementation packages
type = forbidden
source_modules =
    src.config
forbidden_modules =
    src.data
    src.features
    src.strategies
    src.portfolio
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:strategy_boundary]
name = Strategy must not size, trade, execute, persist, or bypass risk
type = forbidden
source_modules =
    src.strategies
forbidden_modules =
    src.config
    src.data
    src.portfolio
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:portfolio_boundary]
name = Portfolio must not depend on strategy implementation or trading layers
type = forbidden
source_modules =
    src.portfolio
forbidden_modules =
    src.config
    src.data
    src.features
    src.strategies
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:feature_independence]
name = Features must stay neutral and avoid stateful trading layers
type = forbidden
source_modules =
    src.features
forbidden_modules =
    src.config
    src.data
    src.strategies
    src.portfolio
    src.risk
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:risk_boundary]
name = Risk must evaluate supplied facts without importing data, config, or downstream layers
type = forbidden
source_modules =
    src.risk
forbidden_modules =
    src.config
    src.data
    src.features
    src.strategies
    src.portfolio
    src.execution
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:execution_boundary]
name = Execution must stay paper-only and avoid upstream/downstream orchestration layers
type = forbidden
source_modules =
    src.execution
forbidden_modules =
    src.config
    src.data
    src.features
    src.strategies
    src.portfolio
    src.risk
    src.accounting
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:accounting_boundary]
name = Accounting must keep virtual ledger state independent from broker and orchestration layers
type = forbidden
source_modules =
    src.accounting
forbidden_modules =
    src.config
    src.data
    src.features
    src.strategies
    src.portfolio
    src.risk
    src.execution
    src.monitoring
    src.backtest
    src.runtime
    src.api
    scripts

[importlinter:contract:backtest_boundary]
name = Backtest composes business packages but must not touch runtime, API, or scripts
type = forbidden
source_modules =
    src.backtest
forbidden_modules =
    src.runtime
    src.api
    src.monitoring
    scripts
